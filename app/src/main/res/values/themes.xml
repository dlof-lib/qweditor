<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.QWEditor" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/qw_accent</item>
        <item name="colorPrimaryDark">@color/qw_bg</item>
        <item name="colorAccent">@color/qw_accent</item>
        <item name="colorSurface">@color/qw_bg_light</item>
        <item name="colorOnSurface">@color/qw_text</item>
        <item name="colorControlHighlight">@color/qw_divider</item>
        <item name="android:windowBackground">@color/qw_bg</item>
        <item name="android:statusBarColor">@color/qw_bg_light</item>
    </style>

    <!-- زر إجراء سريع في شريط أدوات المحرر (Tab, {}, (), ...) -->
    <style name="QwQuickAction" parent="Widget.AppCompat.Button.Borderless">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_marginEnd">6dp</item>
        <item name="android:minWidth">40dp</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="android:background">@drawable/bg_quick_action</item>
        <item name="android:textColor">@color/qw_text</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
